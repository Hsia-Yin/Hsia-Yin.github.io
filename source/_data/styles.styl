/* =========================================================
 * NexT / Gemini - 江雾离骚-湘水夜舟 · maintainable final version
 * 目标：
 * 1. 不依赖 nth-child
 * 2. 按 NexT / Gemini 真实类名覆盖
 * 3. 保持：深蓝外层 + 深色站点头部 + 浅色菜单 / 统计 / TOC
 * 4. 左栏进一步压紧：头部更短、菜单更紧、菜单与统计块更近
 * ========================================================= */


/* ==================== */
/* 1) 配色与字体变量    */
/* ==================== */
c_page_bg    = #18335C
c_header_bg  = #0B183B
c_card_bg    = #E9F0FF
c_text_main  = #24345D
c_text_sub   = #7E8798
c_link       = #34518A
c_hover_bg   = #B7C4D8
c_btn_bg     = #C6D1E0
c_line       = rgba(36, 52, 93, .12)

font_serif   = "Source Han Serif SC", "Noto Serif SC", "Songti SC", "STSong", "SimSun", serif
font_sans    = "Helvetica Neue", Helvetica, Arial, "PingFang SC", "Microsoft YaHei", sans-serif


/* ==================== */
/* 2) 公共 mixin        */
/* ==================== */
flat_card()
  border 0 !important
  border-radius 0 !important
  box-shadow none !important

panel(bg, fg = c_text_main)
  background bg !important
  color fg !important
  flat_card()

no_link_line()
  border 0 !important
  text-decoration none !important
  box-shadow none !important


/* ==================== */
/* 3) 页面基础          */
/* ==================== */
html, body
  margin 0
  padding 0
  background c_page_bg !important
  color c_text_main !important
  font-family font_serif !important

body
  background c_page_bg !important

.container,
.header,
.main,
.footer,
#footer
  background c_page_bg !important

.main
  box-sizing border-box !important

.main-inner
  box-sizing border-box !important

/* 让内容区更干净 */
.content-wrap
  background c_card_bg !important
  flat_card()

.content
  background c_card_bg !important
  padding 42px 48px !important
  box-sizing border-box !important

/* 去掉主题默认白卡 / 阴影 */
.post-block,
.posts-expand .post-block,
.posts-expand .post,
.post,
.page,
.page-post-detail,
.archive,
.category,
.tag,
.comments,
#comments,
.pagination,
.content > article,
.content > div
  background c_card_bg !important
  flat_card()


/* ==================== */
/* 4) 正文排版          */
/* ==================== */
body,
p,
li,
td,
th
  color c_text_main !important
  font-family font_serif !important

p
  font-size 1.03rem !important
  line-height 1.62 !important

li
  line-height 1.85 !important

h1, h2, h3, h4, h5, h6
  color c_text_main !important
  font-family font_serif !important
  font-weight 500 !important
  letter-spacing 0 !important

.post-title,
.post-title-link,
.posts-expand .post-title
  color c_text_main !important
  font-family font_serif !important
  font-weight 500 !important
  font-size 2.15rem !important
  line-height 1.35 !important
  text-align center !important

.post-title-link:hover
  color c_text_main !important
  no_link_line()

.post-meta,
.post-meta-item,
.post-meta-item-text,
.post-time,
.post-category,
.post-category a,
.post-wordcount,
.post-description,
.meta,
time
  color c_text_sub !important
  font-family font_sans !important

.post-meta
  text-align center !important
  margin-top 6px !important
  margin-bottom 34px !important

/* 正文区链接 */
.post-body a,
.page .post-body a,
.page a:not(.site-title):not(.menu-item a)
  color c_link !important
  text-decoration none !important
  border-bottom 1px solid rgba(52, 81, 138, .28) !important

.post-body a:hover,
.page .post-body a:hover,
.page a:not(.site-title):not(.menu-item a):hover
  color c_page_bg !important
  border-bottom 1px solid rgba(24, 51, 92, .48) !important

.post-body img,
.content img
  display block !important
  max-width 100% !important
  height auto !important
  margin 28px auto !important

hr
  border 0 !important
  border-top 1px solid rgba(36, 52, 93, .12) !important


/* ==================== */
/* 5) 按钮              */
/* ==================== */
button,
.btn,
.more,
.more-link,
.read-more .btn,
.post-button .btn,
.pagination .prev,
.pagination .next
  background transparent !important
  color c_text_main !important
  border 1px solid rgba(36, 52, 93, .65) !important
  border-radius 0 !important
  box-shadow none !important
  padding 8px 18px !important
  font-family font_serif !important
  text-decoration none !important

button:hover,
.btn:hover,
.more:hover,
.more-link:hover,
.read-more .btn:hover,
.post-button .btn:hover,
.pagination .prev:hover,
.pagination .next:hover
  background c_btn_bg !important
  color c_page_bg !important
  border-color c_page_bg !important
  text-decoration none !important


/* ==================== */
/* 6) 左侧栏总容器      */
/* ==================== */
.sidebar
  background transparent !important
  flat_card()

.sidebar-inner
  background transparent !important
  padding 0 !important
  flat_card()

.sidebar-panel-container,
.sidebar-panel,
.site-overview-wrap,
.site-overview,
.sidebar-overview
  background transparent !important
  flat_card()

/* 若使用 overview / toc 标签切换 */
.sidebar-nav
  background transparent !important
  margin 0 0 10px 0 !important
  padding 0 !important
  text-align left !important

.sidebar-nav li
  color c_text_sub !important
  font-family font_serif !important

.sidebar-nav .sidebar-nav-active
  color c_text_main !important


/* ==================== */
/* 7) 顶部站点头部块    */
/* 对应：红色框         */
/* ==================== */
.site-brand-container
  panel(c_header_bg, #FFFFFF)
  padding 20px 18px !important
  margin 0 0 3px 0 !important
  text-align center !important

.brand,
.site-meta,
.site-meta-headline,
.custom-logo-site-title,
.site-title-wrap
  background transparent !important
  flat_card()
  margin 0 !important
  padding 0 !important

.site-meta-headline
  margin-bottom 0 !important

.site-title,
.site-title a,
.brand,
.brand a,
.custom-logo-site-title
  color #FFFFFF !important
  font-family font_serif !important
  font-weight 500 !important
  font-size 1.62rem !important
  line-height 1.10 !important
  letter-spacing 0 !important
  text-decoration none !important
  margin 0 !important
  padding 0 !important
  no_link_line()

.site-title a:hover,
.brand a:hover
  color #FFFFFF !important
  no_link_line()

.site-subtitle,
.site-description,
.site-meta .site-subtitle,
.site-meta .site-description
  color rgba(255,255,255,.82) !important
  font-family font_serif !important
  font-size .82rem !important
  line-height 1.35 !important
  margin 4px 0 0 0 !important
  padding 0 !important
  no_link_line()

.site-author-name,
.site-state-item-name,
.links-of-author a,
.links-of-blogroll a
  text-decoration none !important

/* logo 两侧线若存在，取消 */
.logo-line-before,
.logo-line-after
  display none !important


/* ==================== */
/* 8) 菜单块            */
/* 对应：绿色框         */
/* ==================== */
.site-nav
  panel(c_card_bg, c_text_main)
  margin 0 0 4px 0 !important
  padding 0 !important

.site-nav-toggle
  background transparent !important
  flat_card()

.site-nav .menu
  margin 0 !important
  padding 0 !important
  list-style none !important
  background c_card_bg !important
  text-align left !important

.site-nav .menu-item
  margin 0 !important
  padding 0 !important
  list-style none !important
  background transparent !important
  text-align left !important

.site-nav .menu-item a
  display flex !important
  align-items center !important
  justify-content flex-start !important
  gap 14px !important
  padding 8px 22px !important
  color c_text_main !important
  background transparent !important
  border 0 !important
  border-bottom none !important
  text-decoration none !important
  box-shadow none !important
  font-family font_serif !important
  font-size .98rem !important
  line-height 1.20 !important
  transition all .2s ease !important
  margin 0 !important
  text-align left !important

.site-nav .menu-item:last-child a
  border-bottom 0 !important

.site-nav .menu-item a:hover
  background c_hover_bg !important
  color c_page_bg !important
  text-decoration none !important

.site-nav .menu-item-active a,
.site-nav .menu .menu-item-active a,
.site-nav .menu-item.current a
  background c_hover_bg !important
  color c_page_bg !important

/* 主题自带的小圆点 / 激活标记 */
.site-nav .menu-item-active a:after,
.site-nav .menu .menu-item-active a:after,
.site-nav .menu-item.current a:after
  background c_text_sub !important

.site-nav .menu-item i,
.site-nav .menu-item .fa,
.site-nav .menu-item .menu-item-icon
  margin 0 !important
  width 22px !important
  min-width 22px !important
  text-align center !important
  color inherit !important

/* ==================== */
/* 9) 统计块            */
/* 对应：黄色框         */
/* ==================== */
.site-state-wrap
  panel(c_card_bg, c_text_main)
  margin 0 0 14px 0 !important
  padding 12px 14px !important

.site-state
  display flex !important
  justify-content space-between !important
  align-items stretch !important
  gap 6px !important
  margin 0 !important
  background transparent !important
  flat_card()

.site-state-item
  flex 1 1 0 !important
  margin 0 !important
  padding 0 !important
  text-align center !important
  background transparent !important
  flat_card()

.site-state-item a
  width 100% !important
  display flex !important
  flex-direction column !important
  align-items center !important
  justify-content center !important
  text-align center !important
  color inherit !important
  background transparent !important
  no_link_line()

.site-state-item a:hover
  color inherit !important
  background transparent !important
  no_link_line()

.site-state-item-count,
.site-state-item .count,
.site-state-item .num,
.site-state-item .value,
.site-state-item strong,
.site-state-item span:first-child
  display block !important
  width 100% !important
  text-align center !important
  color c_text_main !important
  font-size 18px !important
  font-weight 600 !important
  line-height 1.1 !important
  font-family font_serif !important
  background transparent !important

.site-state-item-name,
.site-state-item .label,
.site-state-item small,
.site-state-item .caption,
.site-state-item span:last-child
  display block !important
  width 100% !important
  margin-top 3px !important
  text-align center !important
  color c_text_sub !important
  font-size 13px !important
  font-weight 400 !important
  line-height 1.2 !important
  font-family font_sans !important
  background transparent !important

/* 统计区上方题句 */
.site-state-wrap
  position relative !important

.site-state-wrap:before
  content "自是人生长恨水长东"
  display block !important
  text-align center !important
  color c_text_sub !important
  font-family font_serif !important
  font-size .92rem !important
  line-height 1.7 !important
  margin 0 0 10px 0 !important
  padding 0 0 10px 0 !important


/* ==================== */
/* 10) TOC / widget 块  */
/* ==================== */
.post-toc-wrap,
.widget,
.widget-wrap,
.links-of-author,
.links-of-blogroll,
.cc-license,
.rss-part,
.sidebar .widget
  panel(c_card_bg, c_text_main)
  margin 0 0 14px 0 !important
  padding 18px 22px !important

.widget-title,
.post-toc .nav-title,
.post-toc .post-toc-title
  color c_text_main !important
  font-family font_serif !important
  font-size 1.03rem !important
  font-weight 500 !important
  margin 0 0 12px 0 !important

.post-toc,
.post-toc ol,
.post-toc ul,
.widget ul,
.widget ol,
.links-of-author,
.links-of-blogroll
  margin 0 !important
  padding 0 !important
  list-style none !important
  background transparent !important

.post-toc li,
.widget li,
.links-of-author li,
.links-of-blogroll li
  margin 0 !important
  padding 0 !important
  list-style none !important

.post-toc a,
.widget a,
.links-of-author a,
.links-of-blogroll a
  display block !important
  color c_text_main !important
  padding 6px 0 !important
  border-bottom 1px solid rgba(36, 52, 93, .16) !important
  text-decoration none !important
  font-family font_serif !important
  background transparent !important

.post-toc li:last-child a,
.widget li:last-child a,
.links-of-author li:last-child a,
.links-of-blogroll li:last-child a
  border-bottom 0 !important

.post-toc a:hover,
.widget a:hover,
.links-of-author a:hover,
.links-of-blogroll a:hover
  color c_page_bg !important
  border-bottom 1px solid rgba(24, 51, 92, .34) !important

.post-toc .active > a,
.post-toc .active-current > a
  color c_page_bg !important


/* ==================== */
/* 11) 页脚             */
/* ==================== */
.footer,
#footer
  background c_page_bg !important
  color rgba(255,255,255,.78) !important
  font-family font_sans !important
  flat_card()

.footer a,
#footer a
  color rgba(255,255,255,.82) !important
  no_link_line()

.footer a:hover,
#footer a:hover
  color #FFFFFF !important
  no_link_line()


/* ==================== */
/* 12) 细节兜底         */
/* ==================== */
/* 防止主题把背景再单独盖回来 */
.site-meta,
.site-nav,
.site-state,
.site-state-wrap,
.post-toc-wrap,
.widget,
.widget-wrap,
.site-overview-wrap,
.sidebar-panel
  box-shadow none !important
  border 0 !important

/* 防止链接默认下划线污染导航 / 侧栏 */
.site-title a,
.site-nav a,
.site-state a,
.post-toc a,
.widget a,
.links-of-author a,
.links-of-blogroll a
  text-decoration none !important

/* 代码块不跟正文混成 serif */
code,
pre,
.highlight,
.highlight 
  font-family "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace !important

/* ==================== */
/* 13) Archive 时间线 - 字体与颜色版 */
/* 只调气质，不改布局 */
/* ==================== */

/* 左侧主竖线：改成雾蓝色 */
.posts-collapse:before
  background rgba(52, 81, 138, .28) !important
  width 6px !important
  border-radius 999px !important

/* 顶部总计：Um..! 1 post. Keep on posting. */
.posts-collapse .collection-title
  color rgba(36, 52, 93, .90) !important
  font-family font_serif !important
  font-size 1.08rem !important
  font-weight 400 !important
  line-height 1.75 !important
  letter-spacing 0 !important

/* 顶部总计左侧圆点 */
.posts-collapse .collection-title:before
  background #8E9098 !important
  border 2px solid c_card_bg !important
  width 14px !important
  height 14px !important
  box-sizing border-box !important

/* 年份：2026 / 2024 / 2023 */
.posts-collapse .collection-title h2,
.posts-collapse .archive-year
  color #24345D !important
  font-family font_serif !important
  font-size 2.05rem !important
  font-weight 600 !important
  line-height 1.18 !important
  letter-spacing 0 !important

/* 年份右侧数量徽标：去掉 */
.posts-collapse .collection-title small,
.posts-collapse .archive-year small
  display none !important

/* 年份节点圆点 */
.posts-collapse .collection-title h2:before,
.posts-collapse .archive-year:before
  background #8E9098 !important
  border 2px solid c_card_bg !important
  width 12px !important
  height 12px !important
  box-sizing border-box !important

/* 每条文章 */
.posts-collapse .post-header
  border-bottom 2px dashed rgba(52, 81, 138, .48) !important
  padding-bottom 12px !important
  margin-bottom 58px !important

/* 每条文章左侧圆点 */
.posts-collapse .post-header:before
  background #8E9098 !important
  border 2px solid c_card_bg !important
  width 11px !important
  height 11px !important
  box-sizing border-box !important

/* 日期：03-09 */
.posts-collapse .post-meta
  color rgba(126, 135, 152, .92) !important
  font-family font_sans !important
  font-size .92rem !important
  font-weight 400 !important
  line-height 1.4 !important

/* 标题：Hsia-Yin */
.posts-collapse .post-title,
.posts-collapse .post-title a
  color #24345D !important
  font-family font_serif !important
  font-size 1.12rem !important
  font-weight 400 !important
  line-height 1.45 !important
  text-decoration none !important
  border 0 !important
  box-shadow none !important

.posts-collapse .post-title a:hover
  color c_link !important
  text-decoration none !important
  border 0 !important

.about-signature
  margin-top 2.8rem !important
  margin-left auto !important
  width fit-content !important
  text-align right !important
  font-family font_serif !important
  font-size 1.02rem !important
  font-style italic !important
  color rgba(36, 52, 93, .82) !important
  line-height 1.7 !important

  /* ==================== */
/* 4.5) 更文气的正文感  */
/* ==================== */
.post-body,
.page .post-body,
.content
  color #24345D !important
  font-family font_serif !important

.post-body p,
.page .post-body p
  font-family font_serif !important
  font-size 1.16rem !important
  line-height 2.18 !important
  letter-spacing .01em !important
  margin 0 0 1.35em 0 !important
  color #24345D !important

.post-body
  max-width 860px !important

.post-body h1,
.post-body h2,
.post-body h3,
.page .post-body h1,
.page .post-body h2,
.page .post-body h3
  font-family font_serif !important
  color #24345D !important
  font-weight 500 !important
  letter-spacing 0 !important

.post-body blockquote,
.page .post-body blockquote
  font-family font_serif !important
  color rgba(36, 52, 93, .88) !important
  border-left 2px solid rgba(52, 81, 138, .28) !important
  padding-left 1.1em !important
  margin 1.6em 0 !important

.post-body a,
.page .post-body a
  color #2F4F88 !important
  border-bottom 1px solid rgba(47, 79, 136, .24) !important

/* 正文：收紧段间距与行距 */
.post-body p,
.page .post-body p
  font-family font_serif !important
  font-size 1.08rem !important
  line-height 1.62 !important
margin 0 0 .62em 0 !important
  letter-spacing 0 !important
  color #24345D !important